    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"# # Minecraft Skin Scraper\",\n",
    "   \"id\": \"2717727afa75f094\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"initial_id\",\n",
    "   \"metadata\": {\n",
    "    \"collapsed\": true\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"from minecraft_skin_scraper import run_pipeline\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Separate paths for images and manifest (skin URLs + metadata)\\n\",\n",
    "    \"UUID_LIST_PATH = '../../../data/skins/general/uuid_list.txt'\\n\",\n",
    "    \"IMAGE_DIRECTORY = '../../data/skins/general/skins/'\\n\",\n",
    "    \"MANIFEST_PATH = '../../../data/skins/general/skin_manifest.csv'\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Optional: process only a row window from uuid_list.txt (0-based, stop exclusive)\\n\",\n",
    "    \"START_ROW = 0\\n\",\n",
    "    \"STOP_ROW = 10000\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Mojang URL resolution parallelism\\n\",\n",
    "    \"MOJANG_MAX_WORKERS = 12\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Full run: UUID list -> DataFrame -> Mojang skin URL -> image download\\n\",\n",
    "    \"skin_df = run_pipeline(\\n\",\n",
    "    \"    uuid_list_path=UUID_LIST_PATH,\\n\",\n",
    "    \"    image_directory=IMAGE_DIRECTORY,\\n\",\n",
    "    \"    manifest_path=MANIFEST_PATH,\\n\",\n",
    "    \"    default_label='unlabeled',\\n\",\n",
    "    \"    save_every=100,\\n\",\n",
    "    \"    start_row=START_ROW,\\n\",\n",
    "    \"    stop_row=STOP_ROW,\\n\",\n",
    "    \"    mojang_max_workers=MOJANG_MAX_WORKERS,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"skin_df.head()\\n\"\n",
    "   ],\n",
    "   \"id\": \"54b171e1d3896481\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
